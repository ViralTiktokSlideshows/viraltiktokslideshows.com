generator client {
  provider = "prisma-client"
  output   = "../generated"
  moduleFormat = "esm"
  runtime = "bun"
}

datasource db {
  provider = "postgresql"
}

// --- Custom auth schema ---
// Hand-rolled, not generated by any auth library. Sessions and magic-link
// requests are opaque random tokens: the raw token is only ever sent to the
// client (as a cookie, or embedded in the emailed link) and never stored —
// only its SHA-256 hash lives in the database, so a leaked database dump
// can't be replayed as a live session or an unused magic link. See
// apps/server/src/lib/session.ts and magic-link.ts.

model User {
  id            String   @id @default(cuid())
  email         String
  name          String?
  image         String?
  emailVerified Boolean  @default(false)
  // Set once the user has signed in with Google at least once. A user can
  // exist from a magic-link sign-in alone (googleId null) and later link
  // Google, since both paths key off the same unique email.
  googleId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions  Session[]
  purchases Purchase[]

  @@unique([email])
  @@unique([googleId])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@unique([tokenHash])
  @@map("session")
}

// A single requested (and, once clicked, consumed) magic-link sign-in.
// `consumedAt` being set makes the token permanently unusable even if it
// hasn't expired yet — magic links are meant to be single-use.
model MagicLinkToken {
  id         String    @id @default(cuid())
  email      String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([tokenHash])
  @@map("magic_link_token")
}

// --- App schema ---

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

// A single $2 unlock of one generated slideshow. Created (PENDING) right
// before we redirect the user to the Dodo Payments checkout, then flipped to
// PAID by the /api/webhooks/dodo handler once Dodo confirms the payment.
// `idea`/`formats`/`vibes`/`slides` are a snapshot of the mock-generated
// slideshow at checkout time — there's no separate Slideshow table yet since
// generation is still the dummy /api/generate endpoint, not persisted.
model Purchase {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea           String
  formats        Json
  vibes          Json
  slides         Json
  amount         Int            @default(200)
  currency       String         @default("USD")
  status         PurchaseStatus @default(PENDING)
  dodoCheckoutId String?
  dodoPaymentId  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([dodoCheckoutId])
  @@map("purchase")
}
