generator client {
  provider = "prisma-client"
  output   = "../generated"
  moduleFormat = "esm"
  runtime = "bun"
}

datasource db {
  provider = "postgresql"
}

// --- Custom auth schema ---
// Hand-rolled, not generated by any auth library. Sessions and magic-link
// requests are opaque random tokens: the raw token is only ever sent to the
// client (as a cookie, or embedded in the emailed link) and never stored --
// only its SHA-256 hash lives in the database, so a leaked database dump
// can't be replayed as a live session or an unused magic link. See
// apps/server/src/lib/session.ts and magic-link.ts.

model User {
  id            String   @id @default(cuid())
  email         String
  name          String?
  image         String?
  emailVerified Boolean  @default(false)
  // Set once the user has signed in with Google at least once. A user can
  // exist from a magic-link sign-in alone (googleId null) and later link
  // Google, since both paths key off the same unique email.
  googleId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Dodo customer id, captured off the first successful payment webhook
  // (payload.data.customer.customer_id) -- see /api/webhooks/dodo. Powers
  // POST /api/billing/portal (Dodo's hosted Customer Portal). Null until
  // someone's first purchase actually clears; there's no "manage billing"
  // to do before that regardless of plan, since Dodo -- not us -- owns
  // payment methods and invoice history.
  dodoCustomerId String?

  // Settings > Generation defaults. Both are real preferences applied
  // server-side (see /api/generate and generate/success's caption
  // builder) -- not cosmetic toggles.
  defaultFormat      SlideFormat @default(STORYTIME)
  autoAppendHashtags Boolean     @default(true)

  // Set true once the user has been through /onboarding -- either started
  // their first slideshow from there or explicitly skipped it. Gates the
  // one-time post-sign-in redirect to /onboarding (see the callback
  // handlers in apps/server/src/index.ts); never shown again after this
  // flips, regardless of path taken.
  hasCompletedOnboarding Boolean @default(false)

  // Subscription plan state, captured off Dodo's subscription.* webhooks
  // (see /api/webhooks/dodo and apps/server/src/lib/plans.ts). Entirely
  // independent of the one-time $2 unlock (Purchase below), which never
  // touches these fields -- a user can buy single unlocks with no plan at
  // all, forever; this is only populated once they subscribe.
  planTier           PlanTier?
  planStatus         PlanStatus?
  dodoSubscriptionId String?
  // Current billing period bounds, from the subscription object's
  // previous_billing_date/next_billing_date. Generations "included in
  // plan" (Purchase.includedInPlan) are counted against rows created
  // within this window to compute usage -- see getPlanUsage() in
  // apps/server/src/lib/plans.ts.
  planPeriodStart    DateTime?
  planPeriodEnd      DateTime?

  sessions  Session[]
  purchases Purchase[]

  @@unique([email])
  @@unique([googleId])
  @@unique([dodoSubscriptionId])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@unique([tokenHash])
  @@map("session")
}

// A single requested (and, once clicked, consumed) magic-link sign-in.
// `consumedAt` being set makes the token permanently unusable even if it
// hasn't expired yet -- magic links are meant to be single-use.
model MagicLinkToken {
  id         String    @id @default(cuid())
  email      String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([tokenHash])
  @@map("magic_link_token")
}

// --- App schema ---

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

// Mirrors Dodo's subscription `status` enum (pending/active/on_hold/
// cancelled/failed/expired), minus PENDING -- a subscription only gets
// written to User at all once Dodo tells us it's ACTIVE for the first
// time (subscription.active), so there's nothing useful to represent
// before that.
enum PlanStatus {
  ACTIVE
  ON_HOLD
  CANCELED
  FAILED
  EXPIRED
}

// One of the three subscription tiers advertised on the landing page's
// Pricing section (apps/web/src/components/landing/pricing.tsx) --
// pricing/quotas for each live in apps/server/src/lib/plans.ts, not here.
enum PlanTier {
  CREATOR
  PRO
  AGENCY
}

// The generation "style" -- no picker step in the generate flow anymore
// (see generate-flow.tsx), applied invisibly from the user's
// Settings > Generation defaults preference instead. Snapshotted onto each
// Purchase at generation time so /dashboard/saved can show what style a
// saved idea was written in.
enum SlideFormat {
  STORYTIME
  LISTICLE
  HOT_TAKE
}

// A single $2 unlock of one generated slideshow, OR one generation drawn
// from an active plan's monthly quota (includedInPlan) -- either way, one
// row per generated-and-unlocked slideshow. $2 unlocks are created PENDING
// right before redirecting to Dodo checkout, then flipped to PAID by the
// /api/webhooks/dodo handler once Dodo confirms payment; plan-covered
// generations skip Dodo entirely and are created already PAID (see POST
// /api/checkout/create's quota-first check).
// `idea`/`formats`/`vibes`/`slides` are a snapshot of the mock-generated
// slideshow at checkout time -- there's no separate Slideshow table yet
// since generation is still the dummy /api/generate endpoint, not
// persisted.
model Purchase {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea           String
  formats        Json
  vibes          Json
  slides         Json
  amount         Int            @default(200)
  currency       String         @default("USD")
  status         PurchaseStatus @default(PENDING)
  dodoCheckoutId String?
  dodoPaymentId  String?
  // Snapshot of the user's Settings > Generation defaults format at the
  // moment this was generated (nullable -- rows created before this field
  // existed have none). Shown as a tag on /dashboard/saved.
  format         SlideFormat?
  // True when this generation was drawn from the user's active plan quota
  // instead of paid for individually -- see getPlanUsage() in
  // apps/server/src/lib/plans.ts, which counts these rows against the
  // current billing period to compute remaining quota.
  includedInPlan Boolean        @default(false)
  // Starred on /dashboard/saved via PATCH /api/purchases/:id. Independent
  // of status -- someone can save a PENDING or even FAILED attempt's idea
  // to retry later, not just PAID ones.
  saved          Boolean        @default(false)
  // Client-generated per-attempt key (see apps/web/src/lib/checkout-client.ts).
  // Lets /api/checkout/create be called more than once for the same unlock
  // attempt (double-click, retry, resumed after magic-link sign-in) without
  // creating a second PENDING purchase -- repeat calls with the same key
  // return the cached checkoutUrl below instead of hitting Dodo again.
  idempotencyKey String?        @unique
  checkoutUrl    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([dodoCheckoutId])
  @@map("purchase")
}
