{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@viraltiktokslideshows/db": "workspace:*",
    "@viraltiktokslideshows/env": "workspace:*",
    "arctic": "^3.7.0",
    "dodopayments": "^2.42.2",
    "dotenv": "catalog:",
    "hono": "^4.12.27",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.10",
    "standardwebhooks": "^1.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/nodemailer": "^6.4.19",
    "@viraltiktokslideshows/config": "workspace:*",
    "tsdown": "^0.22.3",
    "typescript": "^6"
  }
}
