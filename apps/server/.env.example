CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://user:password@localhost:5432/viraltiktokslideshows

# This server's own base URL (not the web app's — that's CORS_ORIGIN above).
SERVER_URL=http://localhost:3000

# Google OAuth — Google Cloud Console > APIs & Services > Credentials.
# Authorized redirect URI: {SERVER_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spacemail SMTP — used by nodemailer to send magic-link emails.
# mail.spacemail.com:465 (SSL) is Spacemail's standard SMTP endpoint.
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_USER=noreply@viraltiktokslideshows.com
SMTP_PASSWORD=
EMAIL_FROM="Viral TikTok Slideshows <noreply@viraltiktokslideshows.com>"

# Dodo Payments — Dashboard > Developer > API / Webhooks.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_UNLOCK_PRODUCT_ID=

# Dodo Payments subscription products — one recurring product per plan
# tier, created in Dashboard > Products after the $2 unlock product above.
# Optional: POST /api/billing/subscribe returns a 501 for any tier whose
# product id isn't set yet rather than the server failing to boot, so these
# can be left blank until each plan is actually ready to sell.
DODO_CREATOR_PRODUCT_ID=
DODO_PRO_PRODUCT_ID=
DODO_AGENCY_PRODUCT_ID=

# OpenRouter — https://openrouter.ai/keys. Used for slide text generation
# via google/gemini-3.5-flash.
OPENROUTER_API_KEY=

# Ideogram — https://ideogram.ai/manage-api. Used for slide background
# images via the v4 generate endpoint. Only the free-preview hook slide
# draws on this now — bulk post-unlock images come from Pexels below.
IDEOGRAM_API_KEY=

# Pexels — https://www.pexels.com/api/ (free, instant signup, no review
# needed). Stock-photo search that backs every non-hook slide image after
# a paid unlock — see apps/server/src/lib/stock-photos.ts. Optional: if
# left blank, fillRemainingSlideImages falls back to Ideogram for
# everything, same as before this was added.
PEXELS_API_KEY=

# Cloudflare R2 — dash.cloudflare.com > R2 > Manage API tokens (create an
# "Object Read & Write" scoped token). Ideogram's image URLs expire, so we
# re-upload every generated image to R2 immediately for permanent storage.
# R2_PUBLIC_URL must have public access enabled on the bucket first
# (Settings > Public Access > enable r2.dev subdomain, or attach a custom
# domain) — paste whichever URL that gives you, no trailing slash.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Cloudflare Turnstile — dash.cloudflare.com > Turnstile. Secret key paired
# with the web app's NEXT_PUBLIC_TURNSTILE_SITE_KEY.
TURNSTILE_SECRET_KEY=
